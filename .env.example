# Required: Your Anthropic API key for Claude
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override the database URL (auto-configured by docker-compose)
# DATABASE_URL=postgres://reviewer:reviewer@localhost:5432/reviews?sslmode=disable

# Optional: Override the LLM model (default: claude-sonnet-4-20250514)
# LLM_MODEL=claude-sonnet-4-20250514

# Optional: Override the server port (default: 8080)
# PORT=8080
